# ridewme — shared environment.
# Copy to `.env` (gitignored) and adjust. Read by BOTH the edge daemon (cli/) and backend (backend/).

# ── Ports ─────────────────────────────────────────────────────────────
# 8000 is RESERVED by sensor-app (the phone-stream hub on `shawarma`). NEVER bind it here.
SENSOR_PORT=8000            # sensor-app hub — external, do not bind locally
BACKEND_PORT=8080           # backend/ HTTP + WebSocket (fleet API + daemon ingest)
FRONTEND_PORT=5173          # Vite dev server (set in the frontend; listed here for the port map)

# ── Hosts ─────────────────────────────────────────────────────────────
SENSOR_HOST=shawarma.chipmunk-balance.ts.net   # phone-stream hub (video + sensors), port 8000
BACKEND_HOST=127.0.0.1                          # where the daemon reaches the backend

# ── Identity ──────────────────────────────────────────────────────────
DRIVER_ID=driver-1          # session_id is generated per daemon run

# ── Daemon uplink ─────────────────────────────────────────────────────
# Derived ingest URL: ws://${BACKEND_HOST}:${BACKEND_PORT}/ws/ingest
INGEST_TOKEN=               # optional shared bearer token; empty = no auth (local dev)

# ── Edge daemon behavior ──────────────────────────────────────────────
CAMERA_SOURCE=phone         # phone | replay   (phone = sensor-app MJPEG; replay = local file / synthetic)
REPLAY_VIDEO=               # path to a video file when CAMERA_SOURCE=replay (blank = synthetic frames)
AUDIO_ENABLED=true          # local in-cabin escalation audio (L5)
NAIVE_MODE=false            # true = naive per-blink detector, for the side-by-side demo
CONTEXT_GATE=false          # L4 "don't nag a parked driver" — OFF by default so it always tracks;
                            # set true for on-road production (suppresses alerts when GPS says stopped)

# ── Database (local Docker Postgres — see database/) ──────────────────
# `cd database && docker compose up -d` starts it with these creds.
POSTGRES_USER=ridewme
POSTGRES_PASSWORD=ridewme
POSTGRES_DB=ridewme
POSTGRES_PORT=5432
# Backend ledger DSN. Swap host/creds for managed Postgres (Supabase/RDS) at deploy time.
DATABASE_URL=postgresql://ridewme:ridewme@127.0.0.1:5432/ridewme

CORS_ORIGINS=*              # comma-separated origins the fleet app may call from
