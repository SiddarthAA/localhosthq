# Collector (backend) base URL the dashboard talks to.
# If unset, it's derived from the page's own host on :8080 — so opening the
# dashboard at http://shawarma:5177 automatically reaches the collector at
# http://shawarma:8080 across the tailnet. Backend CORS is open for local dev.
VITE_BACKEND_URL=http://127.0.0.1:8080

# The single active driver this console focuses on (matches the CLI's DRIVER_ID).
VITE_DRIVER_ID=driver-1
VITE_DRIVER_NAME=Marcus Vale
